---
// 全ページ共通のSEO用metaタグ・ヘッダー/フッターを出力するベースレイアウト。
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/base-url';

interface Props {
	title: string;
	description: string;
	canonicalPath: string; // 例: "/articles/xxxxx/"
	ogType?: 'website' | 'article';
	publishedTime?: string; // ISO文字列(記事ページのみ)
	modifiedTime?: string; // ISO文字列(記事ページのみ)
}

const { title, description, canonicalPath, ogType = 'website', publishedTime, modifiedTime } = Astro.props;

// canonicalPathは常に先頭スラッシュ付きの絶対パス(例: "/", "/articles/xxx/")で渡される。
// GitHub Pagesのプロジェクトページ(base: '/poker-hand-media')ではsite直下ではなくbase配下に
// 実際のページが存在するため、new URL(canonicalPath, Astro.site) だけでは先頭の "/" がbaseを
// 打ち消してしまい誤ったURLになる。withBase()で正しく連結してから解決する。
const canonicalURL = new URL(withBase(canonicalPath), Astro.site);
const siteName = 'ポーカーハンドメディア';
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />

		<!--
			Google Search Console サイト確認用 / Google AdSense 審査用タグは未設定。
			理由: 本サイトは現時点でCloudflare Pages未接続・独自ドメイン未取得の開発段階のため、
			GSC確認・AdSense審査はまだ申請していない(架空のIDを埋め込まないための意図的な未実装)。
			申請後、以下のように実際のIDを追記すること(ai-jitsumu-navi の実装を参照):
			<meta name="google-site-verification" content="実際の確認コード" />
			<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script>
		-->

		<title>{title} | {siteName}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:site_name" content={siteName} />
		{ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<meta name="generator" content={Astro.generator} />
		<slot name="head" />
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>
