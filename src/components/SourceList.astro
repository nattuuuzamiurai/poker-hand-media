---
// 記事の型(標準構成)「7. 出典明記」に対応する自動出力コンポーネント。
// フロントマターの `sources` 配列を構造化データとして受け取り、記事下部に一覧表示する。
// 執筆側(コンテンツ制作部)は本文中に出典見出しを手書きする必要はなく、
// フロントマターに構造化して入力するだけでよい(PrDisclosure / AffiliateProductList と同じ設計)。
//
// 著作権チェックリスト(会社の企画書参照)の
// 「出典(配信名・チャンネル名・記事名)を明記しているか」をここで機械的に担保する。
interface Source {
	label: string;
	url: string;
}

interface Props {
	sources: Source[];
}

const { sources } = Astro.props;
---

{
	sources.length > 0 && (
		<section class="source-list" aria-label="出典">
			<h2 class="source-list__title">出典</h2>
			<p class="source-list__note">
				本記事は以下の配信・記事を情報源とし、そこから読み取れるプレイヤーの思考プロセス・判断の評価を編集部が独自の言葉で再構成したものです。
			</p>
			<ul class="source-list__items">
				{sources.map((source) => (
					<li>
						<a href={source.url} rel="noopener noreferrer" target="_blank">
							{source.label}
						</a>
					</li>
				))}
			</ul>
		</section>
	)
}

<style>
	.source-list {
		margin: 2.5em 0 1em;
		padding: 1.5em 1.75em;
		background: var(--color-bg-subtle);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
	}
	.source-list__title {
		font-size: 1.05rem;
		font-weight: 800;
		color: var(--color-ink);
		margin: 0 0 0.6em;
	}
	.source-list__note {
		font-size: 0.85rem;
		line-height: 1.75;
		color: var(--color-text-muted);
		margin: 0 0 1em;
	}
	.source-list__items {
		margin: 0;
		padding-left: 1.3em;
	}
	.source-list__items li {
		margin-bottom: 0.5em;
		font-size: 0.9rem;
		line-height: 1.7;
	}
	.source-list__items a {
		color: var(--color-brand);
		word-break: break-word;
	}
	.source-list__items a:hover {
		color: var(--color-brand-dark);
	}
</style>
