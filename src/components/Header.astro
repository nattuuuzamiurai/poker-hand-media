---
// 全ページ共通のサイトヘッダー。サイト名・タグラインのみのシンプル構成。
// 2026-07: ポーカーテーブルの「フェルト」を意識した深緑〜黒のグラデーションバーに変更し、
// ロゴマークをトランプチップ風の丸バッジ(スート記号入り)にリニューアル。
---

<header class="site-header">
	<div class="site-header__inner">
		<a href="/" class="site-header__brand">
			<span class="site-header__mark" aria-hidden="true">
				<span class="site-header__mark-suit">♠</span>
			</span>
			<span class="site-header__text">
				<span class="site-header__title">ポーカーハンドメディア</span>
				<span class="site-header__tagline">WSOP・トリトンの名場面ハンド解説</span>
			</span>
		</a>
	</div>
	<div class="site-header__rail" aria-hidden="true"></div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: var(--gradient-felt);
		box-shadow: var(--shadow-md);
	}
	.site-header__inner {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 0.9em 1.25em;
	}
	.site-header__rail {
		height: 3px;
		background: linear-gradient(90deg, transparent, var(--color-gold-light) 20%, var(--color-accent) 50%, var(--color-gold-light) 80%, transparent);
		opacity: 0.9;
	}
	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75em;
		text-decoration: none;
		color: inherit;
	}
	.site-header__mark {
		flex-shrink: 0;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5em;
		height: 2.5em;
		border-radius: 50%;
		background: radial-gradient(circle at 35% 30%, var(--color-brand-light), var(--color-brand-dark) 70%);
		border: 2px solid var(--color-gold-light);
		box-shadow:
			inset 0 0 0 3px rgba(16, 35, 26, 0.55),
			0 2px 6px rgba(0, 0, 0, 0.35);
	}
	.site-header__mark-suit {
		color: #fff;
		font-size: 1.15rem;
		line-height: 1;
	}
	.site-header__text {
		display: flex;
		flex-direction: column;
		line-height: 1.3;
	}
	.site-header__title {
		font-size: 1.15rem;
		font-weight: 800;
		color: #fff;
	}
	.site-header__tagline {
		font-size: 0.78rem;
		color: var(--color-gold-light);
	}

	@media (max-width: 480px) {
		.site-header__tagline {
			display: none;
		}
	}
</style>
