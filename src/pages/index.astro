---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// ローカル開発中はdraft記事もレイアウト確認できるよう表示する(本番ビルドでは除外)。
// 詳細: src/content.config.ts の draft フィールドのコメント参照。
const articles = (
	await getCollection('articles', ({ data }) => !data.draft || import.meta.env.DEV)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	title="WSOP・トリトンの名場面ハンド解説メディア"
	description="WSOP・トリトンポーカーなど大型大会で盛り上がったハンドだけを厳選し、プレイヤーの思考プロセスと判断の評価を独自解説するメディアです。"
	canonicalPath="/"
>
	<main class="page">
		<section class="hero">
			<p class="hero__eyebrow">World Series of Poker × Triton Poker</p>
			<h1 class="hero__title">ポーカーハンドメディア</h1>
			<p class="hero__lead">
				WSOP・トリトンポーカーなど大型大会の配信・解説を情報源に、本当に見るべき「盛り上がったハンド」だけを厳選。プレイヤーが何を考えてそのプレイを選んだのか、その判断は結果的に妥当だったのかを独自の視点で解説します。
			</p>
		</section>

		<section class="article-section">
			<div class="article-section__head">
				<h2 class="section-title">記事一覧</h2>
				<p class="section-count">{articles.length}件の記事</p>
			</div>

			<div class="article-grid">
				{
					articles.length === 0 && (
						<p class="article-empty">まだ公開記事がありません。近日中に初回記事を掲載予定です。</p>
					)
				}
				{
					articles.map((article) => (
						<article class="article-card">
							{article.data.draft && <span class="article-card__draft">DRAFT</span>}
							{article.data.category && <span class="article-card__category">{article.data.category}</span>}
							<h3 class="article-card__title">
								<a href={`/articles/${article.id}/`}>{article.data.title}</a>
							</h3>
							<p class="article-card__desc">{article.data.metaDescription}</p>
							<div class="article-card__meta">
								<time datetime={article.data.pubDate.toISOString()}>{dateFormatter.format(article.data.pubDate)}</time>
								<span class="article-card__readmore" aria-hidden="true">
									続きを読む →
								</span>
							</div>
						</article>
					))
				}
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.page {
		max-width: var(--page-width);
		margin: 0 auto;
		padding: 0 1.25em;
	}

	.hero {
		position: relative;
		padding: 4em 0 3em;
		text-align: center;
		overflow: hidden;
	}
	.hero::before {
		content: '';
		position: absolute;
		inset: -20% -10% auto -10%;
		height: 320px;
		background:
			radial-gradient(circle at 30% 30%, var(--color-brand-bg-strong), transparent 60%),
			radial-gradient(circle at 75% 20%, var(--color-brand-bg), transparent 55%);
		z-index: -1;
		filter: blur(10px);
	}
	.hero__eyebrow {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--color-brand);
		background: var(--color-brand-bg-strong);
		padding: 0.35em 0.9em;
		border-radius: 999px;
		margin: 0 0 1.2em;
	}
	.hero__title {
		font-size: clamp(2.1rem, 5vw, 2.9rem);
		font-weight: 800;
		color: var(--color-ink);
		margin: 0 0 0.6em;
		letter-spacing: -0.01em;
	}
	.hero__lead {
		max-width: 620px;
		margin: 0 auto;
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1.9;
		overflow-wrap: break-word;
	}

	.article-section {
		padding: 1em 0 5em;
	}
	.article-section__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		border-bottom: 2px solid var(--color-border);
		padding-bottom: 0.8em;
		margin-bottom: 2em;
	}
	.section-title {
		position: relative;
		font-size: 1.4rem;
		font-weight: 800;
		color: var(--color-ink);
		margin: 0;
		padding-left: 0.85em;
	}
	.section-title::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.15em;
		bottom: 0.15em;
		width: 5px;
		border-radius: 3px;
		background: linear-gradient(180deg, var(--color-brand-light), var(--color-brand));
	}
	.section-count {
		margin: 0;
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.article-empty {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5em;
	}

	.article-card {
		position: relative;
		display: flex;
		flex-direction: column;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 1.5em;
		box-shadow: var(--shadow-sm);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.article-card:hover,
	.article-card:focus-within {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
		border-color: var(--color-border-strong);
	}
	.article-card__draft {
		align-self: flex-start;
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.05em;
		color: #fff;
		background: var(--color-warn-border);
		padding: 0.25em 0.7em;
		border-radius: 999px;
		margin-bottom: 0.6em;
	}
	.article-card__category {
		align-self: flex-start;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--color-brand-ink);
		background: var(--color-brand-bg-strong);
		padding: 0.3em 0.75em;
		border-radius: 999px;
		margin-bottom: 0.9em;
	}
	.article-card__title {
		font-size: 1.1rem;
		font-weight: 700;
		line-height: 1.5;
		margin: 0 0 0.6em;
		color: var(--color-ink);
		overflow-wrap: break-word;
	}
	.article-card__title a {
		color: inherit;
		text-decoration: none;
	}
	.article-card__title a::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
	}
	.article-card:hover .article-card__title,
	.article-card:focus-within .article-card__title {
		color: var(--color-brand);
	}
	.article-card__desc {
		flex: 1;
		font-size: 0.92rem;
		line-height: 1.8;
		color: var(--color-text-muted);
		margin: 0 0 1.2em;
		overflow-wrap: break-word;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.article-card__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.78rem;
		color: var(--color-text-muted);
		border-top: 1px solid var(--color-border);
		padding-top: 0.9em;
	}
	.article-card__readmore {
		font-weight: 700;
		color: var(--color-brand);
	}

	@media (max-width: 640px) {
		.hero {
			padding: 2.5em 0 2em;
		}
		.article-section__head {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.3em;
		}
	}
</style>
